# Copy to `.env` and adjust. `.env` is gitignored.

NODE_ENV=development

PORT=3000

# Browser frontends allowed to call this API (comma-separated). Production: set real admin URLs.
# In development (NODE_ENV !== production), localhost / 127.0.0.1 on any port is also allowed.
# CORS_ORIGINS=https://admin.bestbond.in,https://bestbond.in,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# SQLite database file (relative to process cwd).
# Production: prefer an absolute path outside the git tree (e.g. /var/lib/reward-system/data.sqlite), or
# beside the API checkout if you accept co-location: /var/www/api.bestbond.in/data.sqlite (add to .gitignore; back up).
# Do not rely on paths inside directories you wipe on every release without backups.
DB_PATH=data.sqlite

# TypeORM synchronize: auto-applies entity schema to the DB. Production defaults to false unless
# DATABASE_SYNCHRONIZE=true (not recommended long-term — use migrations after first deploy).
# DATABASE_SYNCHRONIZE=false

# Behind nginx / a load balancer: set to 1 so rate limits and logs see the real client IP (X-Forwarded-For).
# TRUST_PROXY=1

# CI / Docker slim images: skip Puppeteer Chrome download (PDF features need Chrome installed separately).
# PUPPETEER_SKIP_DOWNLOAD=1

# JWT signing — REQUIRED in production (never use the default dev-secret).
JWT_SECRET=change-me-to-a-long-random-string
# Optional; e.g. 7d, 24h, 3600
JWT_EXPIRES_IN=1h

# --- Dev Super Admin (skipped when NODE_ENV=production) ---
# 10-digit mobile without country code; seeder uses +91 automatically.
DEV_SUPERADMIN_PHONE=9000000000
DEV_SUPERADMIN_EMAIL=admin@admin.in
DEV_SUPERADMIN_NAME=Admin
# Min 8 characters — mobile Management Login → Super Admin → OTP + this password
DEV_SUPERADMIN_PASSWORD=DevSuperAdmin1!
